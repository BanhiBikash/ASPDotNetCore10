@model List<PersonResponse>

<table class="table w-100 mt"> 
	<thead>
		<tr id="properties">
			<th class="sort" name="PersonID">Person ID</th>
			<th class="sort" name="PersonName">Name</th>
			<th class="sort" name="Email">Email</th>
			<th class="sort" name="DateOfBirth">DOB</th>
			<th class="sort" name="Gender">Gender</th>
			<th class="sort" name="Address">Address</th>
			<th class="sort" name="CountryID">Country</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var person in Model)
		{
			<tr>
				<td>@person.PersonID</td>
				<td>@person.PersonName</td>
				<td>@person.Email</td>
				<td>@person.DateOfBirth</td>
				<td>@person.Gender</td>
				<td>@person.Address</td>
				<td>@person.CountryID</td>
			</tr>
		}
	</tbody>
</table>

