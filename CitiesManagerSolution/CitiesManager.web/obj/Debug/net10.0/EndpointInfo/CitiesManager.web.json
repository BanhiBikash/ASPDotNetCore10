{
  "openapi": "3.0.4",
  "info": {
    "title": "CitiesManager.web",
    "version": "1.0"
  },
  "paths": {
    "/api/v1/Cities": {
      "get": {
        "tags": [
          "Cities"
        ],
        "summary": "Retrieves all cities from the data store.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/City"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Cities"
        ],
        "summary": "Creates a new city and adds it to the data store.",
        "description": "If the operation is successful, the response has HTTP status code 201 (Created) and\r\n            includes the created city in the response body. The location header points to the endpoint for retrieving\r\n            the newly created city.",
        "requestBody": {
          "description": "The city entity to add. Must not be null.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/City"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/City"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/City"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/Cities/{id}": {
      "get": {
        "tags": [
          "Cities"
        ],
        "summary": "Retrieves the city with the specified unique identifier.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The unique identifier of the city to retrieve.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/City"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Cities"
        ],
        "summary": "Updates the details of an existing city with the specified identifier.",
        "description": "If the specified city does not exist, the method returns a 404 Not Found response. If\r\n            the id does not match the `CityId` of the provided city, the\r\n            method returns a 400 Bad Request response. Concurrency conflicts during the update will result in an\r\n            exception unless the city no longer exists.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The unique identifier of the city to update.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "description": "The updated city data. The CitiesManager.web.Models.City.CityId property must match the id\r\n            parameter.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/City"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/City"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "delete": {
        "tags": [
          "Cities"
        ],
        "summary": "Deletes the city with the specified unique identifier.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The unique identifier of the city to delete.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/Index": {
      "get": {
        "tags": [
          "Test"
        ],
        "summary": "Handles HTTP GET requests and returns a simple greeting message.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "City": {
        "required": [
          "cityName"
        ],
        "type": "object",
        "properties": {
          "cityId": {
            "type": "string",
            "format": "uuid"
          },
          "cityName": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "Cities"
    },
    {
      "name": "Test"
    }
  ]
}