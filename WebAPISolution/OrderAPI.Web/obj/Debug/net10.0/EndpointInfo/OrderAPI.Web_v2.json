  "components": {
    "schemas": {
      "Order": {
        "required": [
          "customerName",
          "orderDate",
          "orderNo",
          "totalAmount"
        ],
        "type": "object",
        "properties": {
          "orderID": {
            "type": "string",
            "format": "uuid"
          },
          "orderNo": {
            "minLength": 1,
            "pattern": "^Order_\\d{4}_\\d+$",
            "type": "string"
          },
          "customerName": {
            "minLength": 1,
            "type": "string"
          },
          "orderDate": {
            "type": "string",
            "format": "date-time"
          },
          "totalAmount": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "OrderItem": {
        "required": [
          "orderID",
          "productName"
        ],
        "type": "object",
        "properties": {
          "orderItemID": {
            "type": "string",
            "format": "uuid"
          },
          "orderID": {
            "type": "string",
            "format": "uuid"
          },
          "productName": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "quantity": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "unitPrice": {
            "minimum": 0.01,
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "totalPrice": {
            "type": "number",
            "format": "double",
            "nullable": true,
            "readOnly": true
          }
        },
        "additionalProperties": false
      }
    }
