@model List<PersonResponse>

<table class="table w-100 mt"> 
	<thead>
		<tr id="properties">
			@foreach(var property in typeof(PersonResponse).GetProperties())
			{
				<th class="sort" name=@property.Name>@property.Name</th>
			}
			<th>Actions</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var person in Model)
		{
			<tr>
				<td>@person.PersonID</td>
				<td>@person.PersonName</td>
				<td>@person.Email</td>
				<td>@person.DateOfBirth</td>
				<td>@person.Gender</td>
				<td>@person.Address</td>
				<td>@person.CountryID</td>
				<td>@person.Pin</td>
				<td>
					<a asp-action="EditPerson" asp-controller="Home" asp-route-id="@person.PersonID">Edit</a>
					<a asp-action="DeletePerson" asp-controller="Home" asp-route-id="@person.PersonID">Delete</a>
				</td>
			</tr>
		}
	</tbody>
</table>

